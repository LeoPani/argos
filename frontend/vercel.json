{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "regions": ["gru1"],
  "env": {
    "NEXT_PUBLIC_API_URL": "@argos_api_url"
  },
  "build": {
    "env": {
      "ANTHROPIC_API_KEY": "@anthropic_api_key",
      "NEXT_PUBLIC_API_URL": "@argos_api_url"
    }
  }
}
