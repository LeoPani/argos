# =============================================================================
# ARGOS BACKEND - Environment Variables
# Copy this file to .env and fill in real values for your environment.
# =============================================================================

# --- DATABASE (Phase 1) ---
DATABASE_URL=postgres://argos:argos_dev@localhost:5432/argos?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m

# --- HTTP SERVER (Phase 1) ---
API_ADDR=:8080
API_READ_TIMEOUT=15s
API_WRITE_TIMEOUT=30s

# --- AI: BERT Classifier (Phase 1, ACTIVE) ---
AI_BERT_URL=http://localhost:8000
AI_BERT_TIMEOUT=15s
AI_BERT_MAX_RETRIES=2

# --- AI: LLM Generator (Phase 3+, STUB) ---
# Uncomment when implementing prior-art reports / dispute summaries
# AI_LLM_PROVIDER=ollama         # ollama | openai | anthropic
# AI_LLM_URL=http://localhost:11434
# AI_LLM_API_KEY=
# AI_LLM_MODEL=llama3
# AI_LLM_TIMEOUT=120s

# --- Lens.org (Phase 2) ---
# LENS_API_TOKEN=
# LENS_BASE_URL=https://api.lens.org

# --- Web of Science (Phase 6) ---
# WOS_API_KEY=
# WOS_BASE_URL=https://api.clarivate.com

# --- Blockchain / Polygon (Phase 4 - structure only) ---
# BLOCKCHAIN_NETWORK=polygon-amoy  # polygon-mainnet | polygon-amoy
# BLOCKCHAIN_RPC_URL=
# BLOCKCHAIN_PRIVATE_KEY=
# BLOCKCHAIN_CONTRACT_ADDRESS=

# --- Worker (Phase 1+) ---
WORKER_CONCURRENCY=8
WORKER_INPI_DOWNLOAD_DIR=/tmp/argos/rpi

# --- Logging ---
LOG_LEVEL=info     # debug | info | warn | error
LOG_FORMAT=json    # json | text
